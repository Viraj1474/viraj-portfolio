# ============================================================
# Resume Access Request System – Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# For local dev, add http://localhost:5500 or wherever you serve the portfolio.
# For production, use only your actual domain(s).
ALLOWED_ORIGINS=https://virajkulye.me,https://www.virajkulye.me,http://localhost:5500,http://127.0.0.1:5500

# ── Database ─────────────────────────────────────────────────
# SQLite (default – great for a personal project):
DATABASE_URL=sqlite:///./resume_requests.db
# PostgreSQL example (for cloud hosting):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── SMTP ─────────────────────────────────────────────────────
# Gmail example:
#   - Host: smtp.gmail.com
#   - Port: 587
#   - Username: your Gmail address
#   - Password: an App Password (not your account password)
#     See: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=virajkulye1474@gmail.com
SMTP_PASSWORD=grvhiyvwdbtdqjoz

# ── Email addresses ──────────────────────────────────────────
# Email where new-request notifications are sent (typically your own inbox)
OWNER_EMAIL=virajkulye1474@gmail.com
# From address for outgoing emails (usually same as SMTP_USERNAME)
FROM_EMAIL=your_email@gmail.com

# ── Admin credentials ────────────────────────────────────────
ADMIN_USERNAME=admin

# OPTION 1 (recommended for production) – store a bcrypt hash only:
# Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

# OPTION 2 (quick local dev only) – plain text password:
# If ADMIN_PASSWORD_HASH is set, this is ignored.
ADMIN_PASSWORD=change_me_now

# ── URLs ─────────────────────────────────────────────────────
# The public URL of your deployed frontend
FRONTEND_URL=https://virajkulye.me
# The public URL of your deployed backend (used in email links)
BACKEND_PUBLIC_URL=http://localhost:8000

# ── Token settings ────────────────────────────────────────────
# How long (in hours) a download token remains valid after approval
TOKEN_EXPIRY_HOURS=24
# How long (in minutes) to block a duplicate request from the same email
REQUEST_COOLDOWN_MINUTES=60

# ── Resume file ───────────────────────────────────────────────
# Absolute or relative path to the private resume PDF.
# Default (relative to backend/): private/VIRAJK_RESUME.pdf
# For production cloud hosting, set this to the mounted/downloaded path.
# RESUME_PATH=/path/to/your/resume.pdf

# ── Development / Debugging ──────────────────────────────────
# Set to "false" to disable /docs in production
DOCS_ENABLED=true
